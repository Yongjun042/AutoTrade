# ================================================
# AI BRAIN - Environment Configuration
# ================================================

# Server
PORT=3001

# Trading Core API (internal URL)
TRADING_CORE_URL=http://trading-core:8080

# Strategy to run
# Options: mom_v1, trend_v1, rebalance_weekly_v1
STRATEGY_ID=mom_v1

# ================================================
# Ollama (Local LLM) - Optional
# ================================================

# URL to Ollama server
# Leave empty to disable LLM features
OLLAMA_URL=http://localhost:11434

# Model to use
# Options: llama2, llama3, mistral, etc.
OLLAMA_MODEL=llama2
