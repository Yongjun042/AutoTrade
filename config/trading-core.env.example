# ================================================
# TRADING CORE - Environment Configuration
# ================================================

# Server
PORT=8080

# Database (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=tradebot
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=tradebot

# Redis
REDIS_URL=redis://localhost:6379

# ================================================
# KIS (Korea Investment & Securities) API
# ================================================

# Get these from https://www.kiwoom.com/ or your broker
KIS_APP_KEY=YOUR_APP_KEY_HERE
KIS_APP_SECRET=YOUR_APP_SECRET_HERE
KIS_ACCOUNT_NO=YOUR_ACCOUNT_NUMBER

# Environment: REAL (production) or VTS (test)
KIS_ENV=REAL

# Rate limit: 20 for real, 2 for test
KIS_REST_RPS=20

# ================================================
# Safety & Control
# ================================================

# Start with kill switch ON (recommend)
KILL_SWITCH_DEFAULT=true
